          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(vllm:prefix_cache_hits_total[5m])) / clamp_min(sum(rate(vllm:prefix_cache_queries_total[5m])), 1)",
          "legendFormat": "hit ratio",
          "refId": "A"
        }
      ],
      "title": "Prefix Cache Hit Ratio",
      "type": "timeseries"
    },
